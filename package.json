{
  "name": "gantts-app",
  "version": "1.0.0",
  "description": "gantts.app — a free, no-login, 100% client-side Gantt chart maker, plus its static SEO content site. Vanilla HTML/CSS/JS with no backend and no build step.",
  "private": true,
  "type": "commonjs",
  "license": "MIT",
  "author": "Synth88Labs",
  "homepage": "https://gantts.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Synth88Labs/gantts-app.git"
  },
  "bugs": {
    "url": "https://github.com/Synth88Labs/gantts-app/issues"
  },
  "keywords": [
    "gantt",
    "gantt-chart",
    "project-management",
    "critical-path",
    "wbs",
    "static-site",
    "vanilla-javascript",
    "no-backend",
    "pwa"
  ],
  "scripts": {
    "gen:templates": "node scripts/gen-templates.js",
    "gen:thumbs": "node scripts/gen-thumbs.js",
    "gen:assets": "node scripts/gen-assets.js",
    "gen:i18n": "node scripts/gen-i18n.js",
    "gen:sitemap": "node scripts/gen-sitemap.js",
    "build": "npm run gen:favicon && npm run gen:templates && npm run gen:thumbs && npm run gen:pages && npm run gen:i18n && npm run gen:sitemap && npm run check",
    "check:links": "node scripts/check-links.js",
    "check:seo": "node scripts/check-seo.js",
    "check:hreflang": "node scripts/check-hreflang.js",
    "check": "npm run check:links && npm run check:seo && npm run check:hreflang && npm run check:seo-i18n",
    "deploy:bundle": "npm run gen:templates --silent && node scripts/build-deploy.js",
    "indexnow": "node scripts/indexnow.js",
    "test": "npm run check",
    "check:seo-i18n": "node scripts/check-seo-i18n.js",
    "gen:pages": "node scripts/gen-template-pages.js && node scripts/gen-guide-pages.js",
    "deploy:check": "node scripts/deploy-ftp.js --dry",
    "deploy": "npm run preflight && npm run deploy:bundle && node scripts/deploy-ftp.js --yes",
    "preflight": "node scripts/preflight.js",
    "ship": "npm run build && npm run push && npm run deploy && npm run indexnow",
    "push": "git push origin main",
    "gen:favicon": "node scripts/gen-favicon.js"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "pptxgenjs": "^4.0.1",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "basic-ftp": "^6.0.1"
  }
}
