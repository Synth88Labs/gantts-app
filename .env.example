# Copy to .env and fill in. .env is gitignored — it must never be committed,
# and nobody but you should ever need to see it.
#
#   cp .env.example .env
#   npm run deploy:check     # dry run, writes nothing
#   npm run deploy           # real upload

# Use the SERVER's real hostname, not an alias like ftp.gantts.app.
# Shared-hosting FTPS certificates are issued for the provider's own
# domain (here *.web-hosting.com), so an alias fails certificate
# verification and forces you to disable it — which would leave the
# password exposed to anyone on the path.
# Find it with:  nslookup <your site's IP>
FTP_HOST=businessNNN-N.web-hosting.com
FTP_USER=your_ftp_user@gantts.app
FTP_PASS=

# The DOCUMENT ROOT for gantts.app — not the FTP account's home folder.
# Find it in cPanel → Domains → gantts.app → "Document Root".
#
# On a Namecheap cPanel this is usually one of:
#   /home/<cpuser>/gantts.app
#   /home/<cpuser>/public_html          (if gantts.app is the primary domain)
#
# If you point this at an FTP-account subfolder such as
# /home/<cpuser>/gantts.app/admin_ganttsapp the upload will report success
# and the website will stay blank, because those files are served at
# https://gantts.app/admin_ganttsapp/... instead of the root.
FTP_DIR=/home/YOUR_CPANEL_USER/gantts.app

# Port 21 with explicit TLS is the default and what you want.
FTP_PORT=21

# Only set this if your host genuinely cannot do FTPS. Plain FTP sends the
# password across the network in clear text — if you use it, rotate the
# password afterwards.
# FTP_INSECURE=1

# Skips FTPS certificate verification. Only if your host has no hostname
# the certificate covers. Treat as temporary: without verification an
# attacker on the network path can impersonate the server and capture
# the password.
# FTP_ALLOW_BAD_CERT=1
