# Copy to .env and fill in. .env is gitignored and must never be committed.
#
#   cp .env.example .env
#   npm run deploy:check     # dry run, writes nothing
#   npm run deploy           # real upload
#
# Variable names are kept as FTP_* because that is what the deploy
# scripts read. Renaming them here without renaming them there would
# break an existing .env silently.

# Hostname of the destination server.
#
# Use the server's own hostname rather than an alias pointing at your
# domain. TLS certificates on shared infrastructure are issued for the
# provider's hostname, so an alias fails verification — and the usual
# workaround is to disable verification, which leaves the password
# readable to anyone on the network path.
FTP_HOST=
FTP_USER=
FTP_PASS=

# Absolute path to the DOCUMENT ROOT — the directory actually served at
# the site root, which is often not the login account's home directory.
#
# Point this at a subdirectory by mistake and the upload reports success
# while the site stays blank, because the files end up served one level
# below where they are expected.
FTP_DIR=

# Port 21 with explicit TLS is the default and what you want.
FTP_PORT=21

# Only if the destination genuinely cannot do FTPS. Plain FTP sends the
# password in clear text; rotate it afterwards if you ever use this.
# FTP_INSECURE=1

# Skips TLS certificate verification. Temporary measures only — without
# verification, anyone on the network path can impersonate the server and
# capture the password.
# FTP_ALLOW_BAD_CERT=1
