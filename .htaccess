# ==========================================================================
# gantts.app — Apache config for the host / the hosting control panel shared hosting
# Upload alongside index.html in <document-root>.
# ==========================================================================

DirectoryIndex index.html

# ---- No directory listings ----
# /templates/files/, /templates/img/, /assets/, /css/ and /js/ were all
# serving an "Index of …" page. Nothing secret was in them — every file
# there is public and linked — but a listing is still worth closing:
#
#   * it exposes the whole INVENTORY, including anything staged but not
#     yet linked, so an unreleased template slug leaks before launch;
#   * it turns bulk scraping into one request instead of ninety-one;
#   * search engines can index the listing itself as thin, duplicate
#     content that is not in our sitemap, spending crawl budget on a
#     page we would never choose to rank.
#
# The files stay reachable and crawlable by their real URLs. Only the
# auto-generated index goes away.
Options -Indexes

# ---- Correct MIME types ----
<IfModule mod_mime.c>
  AddType image/svg+xml .svg
  AddType application/manifest+json .webmanifest
  AddType text/javascript .js
  AddType application/vnd.openxmlformats-officedocument.spreadsheetml.sheet .xlsx
  AddType application/vnd.openxmlformats-officedocument.presentationml.presentation .pptx
</IfModule>

# ---- Gzip / compression ----
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json application/manifest+json image/svg+xml text/xml application/xml
</IfModule>

# ---- Caching: long for static assets, none for HTML ----
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css               "access plus 7 days"
  ExpiresByType text/javascript        "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresByType image/svg+xml          "access plus 30 days"
  ExpiresByType image/png              "access plus 30 days"
  ExpiresByType image/jpeg             "access plus 30 days"
  ExpiresByType application/vnd.openxmlformats-officedocument.spreadsheetml.sheet "access plus 30 days"
  ExpiresByType application/vnd.openxmlformats-officedocument.presentationml.presentation "access plus 30 days"
  ExpiresByType text/html              "access plus 0 seconds"
</IfModule>

# The service worker must always revalidate so updates ship promptly.
<Files "sw.js">
  <IfModule mod_headers.c>
    Header set Cache-Control "no-cache"
  </IfModule>
</Files>

# ---- Security headers ----
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"

  # HTTPS is already forced by the rewrite below, but a 301 still means
  # the FIRST request of a session can go out in clear text. HSTS removes
  # that window by making the browser rewrite to https itself.
  # Deliberately no `preload` and no `includeSubDomains`: preload is
  # effectively irreversible and should be a considered decision, not a
  # side effect of a security pass.
  Header always set Strict-Transport-Security "max-age=31536000"

  # We ask for none of these. Saying so explicitly means an injected
  # script cannot quietly ask on our behalf.
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=(), interest-cohort=()"

  # ---- Content Security Policy: REPORT-ONLY, deliberately ----
  #
  # This does not block anything yet. It is here to find out what a real
  # policy would break before it breaks it for a visitor. Enforcing a CSP
  # blind on 745 pages is how you discover in production that one page
  # loaded something nobody remembered.
  #
  # The prerequisite is already done: 1483 inline on* handlers across the
  # site were replaced with delegated listeners in js/site.js, so this
  # policy needs no 'unsafe-inline' for scripts. That single attribute is
  # most of what a CSP is for — permitting inline script permits the main
  # thing XSS needs.
  #
  # Still permissive in two places, honestly noted rather than hidden:
  #   * style-src allows 'unsafe-inline' — the app sets bar geometry via
  #     inline style, which is what a Gantt chart is. Removing it means
  #     CSS custom properties for every bar; worth doing, not today.
  #   * script-src allows the two CDNs. They are pinned with Subresource
  #     Integrity, so a compromised CDN still cannot execute — the hash
  #     is the real control there, not the origin allowlist.
  #
  # googletagmanager and google-analytics are listed because analytics
  # loads AFTER consent. Listing them does not load them.
  #
  # NOW ENFORCED. Evidence, gathered on the live site rather than assumed:
  # fifteen code paths exercised with zero violations — consent accept
  # (which loads gtag), PNG, PDF, XLSX, PPTX, CSV, SVG, Mermaid, ICS and
  # MSPDI exports, share-link generation, the lookahead view, the EVM
  # computation, a template load and a full re-render. Fonts resolve, so
  # font-src 'self' is satisfied.
  #
  # ONE PATH IS UNVERIFIED BY EXECUTION: print. It opens a window via
  # window.open(''), which needs a real user gesture, so it could not be
  # driven from an automated pane. The reasoning: an about:blank window
  # inherits the opener's policy, its only resource is a data: image
  # (covered by img-src), and nothing in this policy governs window.open
  # or document.write. The one thing that WOULD have violated — an inline
  # onload="window.print()" — was removed, and check-security.js fails if
  # any inline handler comes back. If print ever breaks, this is the first
  # place to look.
  #
  # The Report-Only header stays alongside deliberately: once enforcing,
  # a violation becomes a broken feature rather than a console message,
  # so keeping the reporting copy means new violations are still visible
  # as violations.
  Header set Content-Security-Policy "default-src 'self'; script-src 'self' https://cdnjs.cloudflare.com https://cdn.jsdelivr.net https://www.googletagmanager.com; connect-src 'self' https://www.google-analytics.com https://*.google-analytics.com https://*.analytics.google.com https://www.googletagmanager.com; img-src 'self' data: blob: https://www.google-analytics.com https://www.googletagmanager.com; style-src 'self' 'unsafe-inline'; font-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'; upgrade-insecure-requests"
  Header set Content-Security-Policy-Report-Only "default-src 'self'; script-src 'self' https://cdnjs.cloudflare.com https://cdn.jsdelivr.net https://www.googletagmanager.com; connect-src 'self' https://www.google-analytics.com https://*.google-analytics.com https://*.analytics.google.com https://www.googletagmanager.com; img-src 'self' data: blob: https://www.google-analytics.com https://www.googletagmanager.com; style-src 'self' 'unsafe-inline'; font-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'; upgrade-insecure-requests"
</IfModule>

# ---- Force HTTPS + non-www ----
# Enabled: SSL is live, and www.gantts.app was serving the entire site
# on a second hostname — all 154 pages returned 200 there. The canonical
# tags pointed at the apex, which limited the damage, but a fully
# crawlable duplicate still splits signals and wastes crawl budget.
#
# The www rule deliberately comes FIRST and rewrites straight to
# https://apex. Putting the HTTPS rule first would send
# http://www -> https://www -> https://apex, costing users an extra
# round trip on every mistyped link.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# ---- Pretty error page ----
ErrorDocument 404 /404.html

# Don't serve build/dev files
<FilesMatch "(package(-lock)?\.json|BUILD-SPEC\.md)">
  Require all denied
</FilesMatch>
RedirectMatch 404 /node_modules/
RedirectMatch 404 /scripts/

# ---- canonical homepage ----
# /index.html and / served identical content at two URLs. Every internal
# link pointed at /index.html while the canonical tag and the sitemap
# both said /, so the site was contradicting itself 366 times. Internal
# links are fixed; this makes the duplicate unreachable rather than
# merely unlinked, since external sites may still link the old form.
RewriteEngine On
# Generalised: ANY directory index, at any depth. The first version
# enumerated / and /<lang>/ and therefore missed /blog/index.html, which
# 308 internal links were still pointing at.
RewriteCond %{THE_REQUEST} \s/+(.*/)?index\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]
